generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Auth.js (NextAuth v5) Prisma adapter models ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  voices        Voice[]
  createdAt     DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- App domain models ---

enum ProjectStatus {
  PLANNING
  DRAFTING
  EDITING
  COMPLETE
}

model Project {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  premise         String?       @db.Text
  genre           String?
  targetWordCount Int?
  status          ProjectStatus @default(PLANNING)
  voiceId         String?
  voice           Voice?        @relation(fields: [voiceId], references: [id], onDelete: SetNull)

  planningDocs      PlanningDocument[]
  chapters          Chapter[]
  editRuns          ManuscriptEditRun[]
  interviewMessages StyleInterviewMessage[]
  manuscriptFiles   ManuscriptFile[]
  chatMessages      ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([voiceId])
}

enum PlanningDocType {
  REFERENCE_PLOT
  CHARACTER_PROFILES
  STORY_STRUCTURE
  STYLE_BRIEF
}

model PlanningDocument {
  id        String          @id @default(cuid())
  projectId String
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      PlanningDocType
  data      Json
  content   String          @db.Text
  version   Int             @default(1)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([projectId, type])
}

enum MessageRole {
  USER
  ASSISTANT
}

// The running chat transcript behind the Style Interview. Kept separate from
// PlanningDocument because it's a conversation, not a single structured
// artifact - only its distilled result becomes a PlanningDocument row.
model StyleInterviewMessage {
  id        String      @id @default(cuid())
  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role      MessageRole
  content   String      @db.Text
  createdAt DateTime    @default(now())

  @@index([projectId, createdAt])
}

// The freeform project-scoped Chat assistant's transcript - a separate
// conversation from StyleInterviewMessage since it's open-ended discussion,
// not a structured intake.
model ChatMessage {
  id        String      @id @default(cuid())
  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role      MessageRole
  content   String      @db.Text
  createdAt DateTime    @default(now())

  @@index([projectId, createdAt])
}

// A raw uploaded draft file, persisted independently of whether it has been
// turned into Chapter rows yet. A project can hold several - a full draft,
// or separate files per chapter/part - listed on the project's Files tab.
model ManuscriptFile {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  filename      String
  extractedText String   @db.Text
  wordCount     Int      @default(0)
  createdAt     DateTime @default(now())

  @@index([projectId, createdAt])
}

enum ChapterStatus {
  EMPTY
  DRAFTED
  EDITING
  FINAL
}

enum ChapterSource {
  AI_GENERATED
  UPLOADED
}

model Chapter {
  id              String        @id @default(cuid())
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  order           Int
  title           String
  content         String        @db.Text
  previousContent String?       @db.Text
  status          ChapterStatus @default(EMPTY)
  source          ChapterSource @default(AI_GENERATED)
  wordCount       Int           @default(0)
  lastInstruction String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([projectId, order])
}

enum EditRunType {
  CONTINUITY_PASS
  STYLE_POLISH
  FULL_MANUSCRIPT
}

model ManuscriptEditRun {
  id        String      @id @default(cuid())
  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      EditRunType
  model     String
  summary   Json
  createdAt DateTime    @default(now())

  @@index([projectId])
}

enum VoiceSampleSource {
  MANUAL
  SAVED_FROM_CHAPTER
}

// A persistent, cross-project writing-style profile - unlike everything else
// in this schema, scoped directly to User rather than through a Project, so
// it can be reused across any number of books. Projects attach one Voice
// optionally (Project.voiceId); the Voice itself is unaffected by deleting
// any project that used it.
model Voice {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.Text
  data        Json
  content     String   @db.Text
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  versions          VoiceVersion[]
  samples           VoiceSample[]
  interviewMessages VoiceInterviewMessage[]
  projects          Project[]

  @@index([userId])
}

// Snapshot of a Voice's data/content taken immediately before each
// overwrite, so edits and AI regenerations can be undone via restore.
model VoiceVersion {
  id        String   @id @default(cuid())
  voiceId   String
  voice     Voice    @relation(fields: [voiceId], references: [id], onDelete: Cascade)
  version   Int
  data      Json
  content   String   @db.Text
  note      String?
  createdAt DateTime @default(now())

  @@unique([voiceId, version])
  @@index([voiceId, createdAt])
}

// Reference writing samples that ground AI generation/regeneration of a
// Voice's Brain - either pasted in manually or saved from an existing
// chapter written in that voice.
model VoiceSample {
  id        String            @id @default(cuid())
  voiceId   String
  voice     Voice             @relation(fields: [voiceId], references: [id], onDelete: Cascade)
  label     String
  content   String            @db.Text
  source    VoiceSampleSource @default(MANUAL)
  createdAt DateTime          @default(now())

  @@index([voiceId, createdAt])
}

// The running chat transcript behind a Voice's creation interview - mirrors
// StyleInterviewMessage's role in the project-scoped Style Interview, but
// scoped to a Voice instead. Only its distilled result updates Voice.content.
model VoiceInterviewMessage {
  id        String      @id @default(cuid())
  voiceId   String
  voice     Voice       @relation(fields: [voiceId], references: [id], onDelete: Cascade)
  role      MessageRole
  content   String      @db.Text
  createdAt DateTime    @default(now())

  @@index([voiceId, createdAt])
}
