# Postgres (Neon or similar) — pooled connection string for the app,
# direct (non-pooled) connection string for Prisma migrations.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js
AUTH_SECRET="generate-with-npx-auth-secret"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Gemini (currently in use — full swap from Anthropic "for now", see lib/claude/client.ts)
GEMINI_API_KEY=""

# Anthropic (unused while the Gemini swap is active; kept for an easy revert)
ANTHROPIC_API_KEY=""
