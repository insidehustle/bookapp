    "@tiptap/pm": "^3.27.4",
    "@tiptap/react": "^3.27.4",
    "@tiptap/starter-kit": "^3.27.4",
    "mammoth": "^1.9.0",
    "next": "^15.5.0",
    "next-auth": "5.0.0-beta.29",
    "pdf-parse": "^1.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "tiptap-markdown": "^0.9.0",
